{
  "name": "@magic-ingredients/no-tickets",
  "version": "3.0.0",
  "description": "SDK for no-tickets — ticketless project management for AI teams",
  "type": "module",
  "main": "dist/core/index.js",
  "types": "dist/core/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./types": {
      "types": "./dist/core/types.d.ts",
      "import": "./dist/core/types.js"
    },
    "./schemas": {
      "types": "./dist/core/schemas.d.ts",
      "import": "./dist/core/schemas.js"
    },
    "./sdk": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    }
  },
  "files": [
    "dist",
    "templates",
    "wrappers"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc --watch",
    "test": "vitest run",
    "lint": "eslint src/",
    "test:coverage": "vitest run --coverage",
    "test:mutate": "npx stryker run",
    "typecheck": "tsc --noEmit",
    "rust:check": "cargo check -p nt-cli --tests",
    "rust:clippy": "cargo clippy -p nt-cli --all-targets -- -D warnings",
    "rust:fmt": "cargo fmt --check -p nt-cli",
    "rust:fmt:fix": "cargo fmt -p nt-cli",
    "rust:test": "cargo test -p nt-cli",
    "rust:mutants": "cargo mutants --package nt-cli",
    "rust:precommit": "pnpm rust:fmt && pnpm rust:clippy && pnpm rust:check"
  },
  "dependencies": {
    "@magic-ingredients/no-tickets-schemas": "^0.2.0",
    "gray-matter": "^4.0.3",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/vitest-runner": "^9.6.0",
    "@types/node": "^25.5.2",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9.0.0",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.0"
  },
  "packageManager": "pnpm@10.27.0",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/magic-ingredients/no-tickets.git"
  },
  "keywords": [
    "no-tickets",
    "project-management",
    "ai",
    "sdk",
    "ticketless"
  ]
}
