{
  "name": "@magic-ingredients/no-tickets",
  "version": "2.0.5",
  "description": "CLI, MCP server, and SDK for no-tickets — ticketless project management for AI teams",
  "type": "module",
  "main": "dist/core/index.js",
  "types": "dist/core/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./types": {
      "types": "./dist/core/types.d.ts",
      "import": "./dist/core/types.js"
    },
    "./schemas": {
      "types": "./dist/core/schemas.d.ts",
      "import": "./dist/core/schemas.js"
    },
    "./sdk": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    }
  },
  "files": [
    "dist",
    "bin",
    "templates",
    "wrappers"
  ],
  "bin": {
    "no-tickets": "bin/no-tickets.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:unit": "vitest run --exclude '**/auth-server.test.ts' --exclude '**/*-e2e.test.ts'",
    "lint": "eslint src/",
    "test:coverage": "vitest run --coverage",
    "test:mutate": "npx stryker run",
    "typecheck": "tsc --noEmit",
    "prepack": "chmod +x bin/no-tickets.js"
  },
  "dependencies": {
    "@magic-ingredients/no-tickets-schemas": "^0.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "gray-matter": "^4.0.3",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/vitest-runner": "^9.6.0",
    "@types/node": "^25.5.2",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9.0.0",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.0"
  },
  "packageManager": "pnpm@10.27.0",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/magic-ingredients/no-tickets.git"
  },
  "keywords": [
    "no-tickets",
    "project-management",
    "ai",
    "mcp",
    "cli",
    "ticketless"
  ]
}
